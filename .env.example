# Shared
NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:3000
API_ORIGIN=http://localhost:4000
ALLOWED_ORIGINS=
ALLOW_MISSING_ORIGIN_FOR_DEV=false
SESSION_COOKIE_NAME=zeeus_assessment_session
SESSION_COOKIE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
SSO_STATE_ENCRYPTION_KEY=abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789
ARGON2_MEMORY_COST=19456
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
SESSION_ROTATION_MS=43200000
SESSION_TOUCH_INTERVAL_MS=600000
SESSION_MAX_ACTIVE=5
OWNER_STEP_UP_WINDOW_MS=900000
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_CLEANUP_INTERVAL_MS=900000
IDEMPOTENCY_CLEANUP_BATCH_SIZE=500
AUDIT_LOG_RETENTION_DAYS=365
SESSION_RETENTION_DAYS=30
PASSWORD_RESET_RETENTION_DAYS=30
IDEMPOTENCY_RETENTION_DAYS=7
EXPORT_SYNC_LIMIT=5000
EXPOSE_DEV_RESET_DETAILS=false
ARTIFACTS_DIR=.artifacts
INTERNAL_SERVICE_TOKEN=zeeus-internal-token
WEB_INTERNAL_ORIGIN=http://localhost:3000
ENABLE_INTERNAL_SURFACES=false
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=zeeus_assessment
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zeeus_assessment?schema=public

# API
API_PORT=4000
API_PREFIX=api
ENTERPRISE_IDENTITY_ENABLED=false
ENTERPRISE_DEFAULT_PROVIDER_SLUG=
BREAK_GLASS_LOCAL_LOGIN_ENABLED=false

# Enterprise identity
# Recommended production posture: configure OIDC first, set
# ENTERPRISE_DEFAULT_PROVIDER_SLUG to the OIDC provider slug, and enable SAML or
# SCIM only when a target deployment requires them.
OIDC_PROVIDER_SLUG=
OIDC_PROVIDER_DISPLAY_NAME=
OIDC_ISSUER=
OIDC_AUTHORIZATION_ENDPOINT=
OIDC_TOKEN_ENDPOINT=
OIDC_JWKS_URI=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid,profile,email
OIDC_VERIFIED_DOMAINS=
OIDC_GROUP_CLAIM=groups
OIDC_EMAIL_CLAIM=email
OIDC_SUBJECT_CLAIM=sub
OIDC_GROUP_ROLE_MAPPINGS=
SAML_PROVIDER_SLUG=
SAML_PROVIDER_DISPLAY_NAME=
SAML_SSO_URL=
SAML_ENTITY_ID=
SAML_CERTIFICATE_PEM=
SAML_VERIFIED_DOMAINS=
SAML_GROUP_ATTRIBUTE=groups
SAML_EMAIL_ATTRIBUTE=email
SAML_SUBJECT_ATTRIBUTE=NameID
SAML_GROUP_ROLE_MAPPINGS=
SCIM_BEARER_TOKEN=

# WEB
WEB_PORT=3000
CSP_REPORT_ONLY=false
CSP_REPORT_URI=

# Seed
SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_PASSWORD=ChangeMe123!

# Optional integrations
FEATURE_EMAIL=false
FEATURE_STORAGE=false
FEATURE_CACHE=false
FEATURE_OBSERVABILITY=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
S3_BUCKET=zeeus-artifacts
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
OTEL_EXPORTER_OTLP_ENDPOINT=

