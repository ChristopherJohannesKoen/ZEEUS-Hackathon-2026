# Perf profile overrides layered on top of .env / .env.example
NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:3000
API_ORIGIN=http://localhost:4000
ALLOW_MISSING_ORIGIN_FOR_DEV=false
EXPOSE_DEV_RESET_DETAILS=false
