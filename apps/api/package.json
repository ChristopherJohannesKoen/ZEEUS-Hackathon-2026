{
  "name": "@apps/api",
  "private": true,
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/main.ts",
    "build": "tsc -p tsconfig.build.json --incremental false",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate --schema ../../packages/db/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema ../../packages/db/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema ../../packages/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "file:../../vendor/nestjs-config-4.0.3.tgz",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "file:../../vendor/nestjs-swagger-11.2.6.tgz",
    "@nestjs/throttler": "^6.4.0",
    "@opentelemetry/auto-instrumentations-node": "^0.66.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.206.0",
    "@opentelemetry/sdk-node": "^0.206.0",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@packages/contracts": "file:../../packages/contracts",
    "@packages/scoring": "file:../../packages/scoring",
    "@packages/shared": "file:../../packages/shared",
    "@prisma/client": "^6.6.0",
    "@ts-rest/nest": "^3.52.1",
    "@xmldom/xmldom": "^0.9.8",
    "argon2": "^0.41.1",
    "bullmq": "^5.61.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "fast-xml-parser": "^5.3.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "joi": "^17.13.3",
    "jose": "^6.1.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0",
    "xml-crypto": "^6.1.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.18",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.2",
    "@types/supertest": "^7.2.0",
    "prisma": "^6.6.0",
    "supertest": "^7.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
