{
  "name": "zeeus-hackathon-assessment-platform",
  "private": true,
  "version": "2.0.0",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run prisma:generate && npm run build:runtime-packages",
    "build": "turbo run build",
    "build:runtime-packages": "npm run build --workspace=@packages/shared --workspace=@packages/contracts --workspace=@packages/scoring",
    "dev": "npm run build:runtime-packages && node ./scripts/with-env.mjs turbo run dev --parallel --filter=@packages/shared --filter=@packages/contracts --filter=@packages/scoring --filter=@apps/api --filter=@apps/web --filter=@apps/worker",
    "dev:services": "docker compose up db redis minio bucket-init -d",
    "docs:lint": "markdownlint-cli2 \"README.md\" \"docs/**/*.md\" \"tests/perf/**/*.md\"",
    "docs:links": "node ./scripts/check-markdown-links.mjs",
    "docs:check": "npm run docs:lint && npm run docs:links",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "node ./scripts/with-env.mjs turbo run test",
    "test:e2e": "npm run build:runtime-packages && node ./scripts/with-e2e-env.mjs playwright test tests/e2e/public-auth.spec.ts tests/e2e/evaluations.spec.ts",
    "test:e2e:enterprise": "node ./scripts/with-enterprise-e2e-env.mjs playwright test tests/e2e/enterprise-login.spec.ts",
    "test:e2e:headed": "node ./scripts/with-e2e-env.mjs playwright test --headed",
    "test:e2e:ui": "node ./scripts/with-e2e-env.mjs playwright test --ui",
    "test:perf:auth": "node ./scripts/with-perf-env.mjs k6 run tests/perf/auth-session-churn.js",
    "test:perf:critical": "node ./scripts/with-perf-env.mjs k6 run tests/perf/api-critical-paths.js",
    "test:perf:read": "node ./scripts/with-perf-env.mjs k6 run tests/perf/dashboard-read.js",
    "test:perf:idempotency": "node ./scripts/with-perf-env.mjs k6 run tests/perf/evaluation-create-idempotent.js",
    "test:perf:reset": "node ./scripts/with-perf-env.mjs k6 run tests/perf/password-reset-burst.js",
    "test:perf:smoke": "node ./scripts/with-perf-env.mjs k6 run tests/perf/smoke.js",
    "perf:up": "node ./scripts/with-perf-env.mjs docker compose up --build -d --force-recreate db redis minio bucket-init api web worker",
    "perf:down": "docker compose down --remove-orphans",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "db:setup": "node ./scripts/with-env.mjs npm run prisma:migrate:dev --workspace=@packages/db && node ./scripts/with-env.mjs npm run seed --workspace=@packages/db",
    "db:reset": "node ./scripts/with-env.mjs npm run prisma:reset --workspace=@packages/db",
    "prisma:generate": "node ./scripts/with-env.mjs npm run prisma:generate --workspace=@packages/db",
    "prisma:migrate:deploy": "node ./scripts/with-env.mjs npm run prisma:migrate:deploy --workspace=@packages/db",
    "seed": "node ./scripts/with-env.mjs npm run seed --workspace=@packages/db",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down --remove-orphans"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.0.0",
    "@next/eslint-plugin-next": "^16.2.2",
    "@playwright/test": "^1.59.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^16.4.7",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.14",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.14.0",
    "jsdom": "^26.1.0",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.5.3",
    "turbo": "^2.4.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.2"
  }
}
