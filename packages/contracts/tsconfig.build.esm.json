{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "dist/types",
    "emitDeclarationOnly": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist/esm",
    "tsBuildInfoFile": "dist/.tsbuildinfo.esm"
  },
  "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts"]
}
