{
  "name": "@packages/db",
  "private": true,
  "scripts": {
    "build": "node -e \"require('node:fs').mkdirSync('dist', { recursive: true }); require('node:fs').writeFileSync('dist/.prisma-generated', 'ok');\"",
    "dev": "npm run prisma:generate",
    "lint": "node ../../scripts/with-env.mjs prisma validate --schema ./prisma/schema.prisma",
    "typecheck": "node ../../scripts/with-env.mjs prisma validate --schema ./prisma/schema.prisma",
    "test": "node ../../scripts/with-env.mjs node ./prisma/seed.mjs --dry-run",
    "prisma:generate": "node ../../scripts/with-env.mjs prisma generate --schema ./prisma/schema.prisma && node ../../scripts/sync-prisma-client-files.mjs",
    "prisma:migrate:dev": "node ../../scripts/with-env.mjs prisma migrate dev --schema ./prisma/schema.prisma",
    "prisma:migrate:deploy": "node ../../scripts/with-env.mjs prisma migrate deploy --schema ./prisma/schema.prisma",
    "prisma:reset": "node ../../scripts/with-env.mjs prisma migrate reset --force --skip-generate --skip-seed --schema ./prisma/schema.prisma && npm run prisma:generate && npm run seed",
    "seed": "node ../../scripts/with-env.mjs node ./prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "argon2": "^0.41.1"
  },
  "devDependencies": {
    "prisma": "^6.6.0"
  }
}
