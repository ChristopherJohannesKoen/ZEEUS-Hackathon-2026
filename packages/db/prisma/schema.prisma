generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String
  passwordHash        String?
  role                Role                 @default(member)
  disabledAt          DateTime?
  disabledReason      String?
  provisionedBy       IdentityProviderType?
  bootstrapOwnership  BootstrapState?      @relation("BootstrapOwner")
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]           @relation("AuditActor")
  identities          UserIdentity[]
  groupMemberships    UserGroupMembership[]
  accessPolicyActor   AccessPolicyEvent[]  @relation("AccessPolicyActor")
  accessPolicyTarget  AccessPolicyEvent[]  @relation("AccessPolicyTarget")
  evaluations         Evaluation[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([disabledAt])
}

model BootstrapState {
  id               Int      @id @default(1)
  bootstrapOwnerId String   @unique
  bootstrapOwner   User     @relation("BootstrapOwner", fields: [bootstrapOwnerId], references: [id], onDelete: Restrict)
  completedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Session {
  id             String   @id @default(cuid())
  tokenHash      String   @unique
  csrfTokenHash  String
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  authMethod     SessionAuthMethod @default(local)
  authReason     SessionAuthReason @default(local_login)
  identityProviderId String?
  identityProvider IdentityProviderConfig? @relation(fields: [identityProviderId], references: [id], onDelete: SetNull)
  externalSubject String?
  stepUpAt       DateTime?
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  lastUsedAt     DateTime @default(now())
  lastRotatedAt  DateTime @default(now())
  ipAddress      String?
  userAgent      String?

  @@index([userId])
  @@index([expiresAt])
  @@index([lastRotatedAt])
  @@index([identityProviderId])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String    @id @default(cuid())
  actorId    String?
  actor      User?     @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  eventCategory AuditEventCategory @default(application)
  outcome    AuditOutcome @default(success)
  authMechanism SessionAuthMethod?
  targetType String
  targetId   String?
  requestId  String?
  ipAddress  String?
  userAgent  String?
  legalHold  Boolean   @default(false)
  previousHash String?
  entryHash  String    @unique
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([eventCategory, createdAt])
  @@index([legalHold, createdAt])
}

model IdempotencyRequest {
  id                 String            @id @default(cuid())
  scope              String
  idempotencyKey     String
  method             String
  path               String
  fingerprint        String
  status             IdempotencyStatus @default(pending)
  responseStatusCode Int?
  responseBody       Json?
  expiresAt          DateTime
  completedAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([scope, idempotencyKey, method, path])
  @@index([expiresAt])
}

model Evaluation {
  id                   String                  @id @default(cuid())
  userId               String
  user                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  country              String
  naceDivision         String
  offeringType         OfferingType
  launched             Boolean
  currentStage         StartupStage
  innovationApproach   InnovationApproach
  status               EvaluationStatus        @default(draft)
  currentStep          EvaluationStep          @default(start)
  currentRevisionId    String?
  currentRevisionNumber Int                    @default(0)
  scoringVersion       String                  @default("2026.04.ready-software.1")
  catalogVersion       String                  @default("workbook-catalog")
  completedAt          DateTime?
  archivedAt           DateTime?
  lastScoredAt         DateTime?
  financialTotal       Int                     @default(0)
  riskOverall          Float                   @default(0)
  opportunityOverall   Float                   @default(0)
  confidenceBand       ConfidenceBand          @default(low)
  relevantTopicCount   Int                     @default(0)
  highPriorityTopicCount Int                   @default(0)
  stage1Financial      Stage1FinancialAnswer?
  stage1TopicAnswers   Stage1TopicAnswer[]
  stage2RiskAnswers    Stage2RiskAnswer[]
  stage2OpportunityAnswers Stage2OpportunityAnswer[]
  revisions            EvaluationRevision[]
  artifacts            EvaluationArtifact[]
  recommendationActions EvaluationRecommendationAction[]
  narratives           EvaluationNarrative[]
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@index([userId, updatedAt])
  @@index([currentRevisionId])
}

model Stage1FinancialAnswer {
  evaluationId      String                  @id
  evaluation        Evaluation              @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  roiLevel          FinancialRoiLevel
  sensitivityLevel  FinancialSensitivityLevel
  uspLevel          FinancialUspLevel
  marketGrowthLevel FinancialMarketGrowthLevel
  totalScore        Int
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
}

model Stage1TopicAnswer {
  id              String                @id @default(cuid())
  evaluationId    String
  evaluation      Evaluation            @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  topicCode       TopicCode
  applicable      Boolean               @default(true)
  magnitude       ImpactDimensionLevel
  scale           ImpactDimensionLevel
  irreversibility ImpactDimensionLevel
  likelihood      ImpactLikelihoodLevel
  evidenceBasis   EvidenceBasis
  evidenceNote    String?
  impactScore     Float                 @default(0)
  priorityBand    PriorityBand          @default(not_applicable)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([evaluationId, topicCode])
  @@index([priorityBand])
}

model Stage2RiskAnswer {
  id            String                @id @default(cuid())
  evaluationId  String
  evaluation    Evaluation            @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  riskCode      RiskCode
  applicable    Boolean               @default(true)
  probability   RiskProbabilityLevel
  impact        ImpactDimensionLevel
  evidenceBasis EvidenceBasis
  evidenceNote  String?
  ratingLabel   RiskRatingLabel       @default(neutral)
  ratingScore   Float                 @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([evaluationId, riskCode])
  @@index([ratingLabel])
}

model Stage2OpportunityAnswer {
  id              String                 @id @default(cuid())
  evaluationId    String
  evaluation      Evaluation             @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  opportunityCode OpportunityCode
  applicable      Boolean                @default(true)
  likelihood      RiskProbabilityLevel
  impact          ImpactDimensionLevel
  evidenceBasis   EvidenceBasis
  evidenceNote    String?
  ratingLabel     OpportunityRatingLabel @default(neutral)
  ratingScore     Float                  @default(0)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([evaluationId, opportunityCode])
  @@index([ratingLabel])
}

model SdgMapping {
  id                String        @id @default(cuid())
  sourceType        SdgSourceType
  startupStage      StartupStage?
  naceDivisionCode  String?
  naceDivisionLabel String?
  sdgNumber         Int
  sdgName           String
  createdAt         DateTime      @default(now())

  @@index([sourceType, startupStage, sdgNumber])
  @@index([sourceType, naceDivisionCode, sdgNumber])
}

model RecommendationTemplate {
  id                 String             @id @default(cuid())
  code               String
  recommendationType RecommendationType
  severityBand       String
  title              String
  text               String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([code, recommendationType, severityBand])
}

model EvaluationRevision {
  id                    String           @id @default(cuid())
  evaluationId          String
  evaluation            Evaluation       @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  revisionNumber        Int
  status                EvaluationStatus
  currentStep           EvaluationStep
  scoringVersion        String
  catalogVersion        String
  detailSnapshot        Json
  impactSummarySnapshot Json
  dashboardSnapshot     Json
  reportSnapshot        Json
  createdByUserId       String?
  createdAt             DateTime         @default(now())
  artifacts             EvaluationArtifact[]
  recommendationActions EvaluationRecommendationAction[]
  narratives            EvaluationNarrative[]

  @@unique([evaluationId, revisionNumber])
  @@index([evaluationId, createdAt])
}

model EvaluationArtifact {
  id              String                   @id @default(cuid())
  evaluationId    String
  evaluation      Evaluation               @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  revisionId      String?
  revision        EvaluationRevision?      @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  kind            EvaluationArtifactKind
  status          EvaluationArtifactStatus @default(pending)
  filename        String
  mimeType        String
  byteSize        Int
  storageKey      String?
  checksumSha256  String?
  requestedAt     DateTime                 @default(now())
  readyAt         DateTime?
  failedAt        DateTime?
  errorMessage    String?
  createdByUserId String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([evaluationId, createdAt])
  @@index([revisionId])
  @@index([status, kind, createdAt])
}

model EvaluationRecommendationAction {
  id               String                     @id @default(cuid())
  evaluationId     String
  evaluation       Evaluation                 @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  revisionId       String
  revision         EvaluationRevision         @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  recommendationId String
  status           RecommendationActionStatus @default(not_started)
  ownerNote        String?
  updatedByUserId  String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@unique([revisionId, recommendationId])
  @@index([evaluationId, status])
  @@index([revisionId, status])
}

model EvaluationNarrative {
  id              String                    @id @default(cuid())
  evaluationId    String
  evaluation      Evaluation                @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  revisionId      String?
  revision        EvaluationRevision?       @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  kind            EvaluationNarrativeKind
  status          EvaluationNarrativeStatus @default(pending)
  model           String?
  promptVersion   String?
  content         String?
  requestedAt     DateTime                  @default(now())
  readyAt         DateTime?
  failedAt        DateTime?
  errorMessage    String?
  createdByUserId String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([evaluationId, createdAt])
  @@index([revisionId])
  @@index([status, kind, createdAt])
}

model IdentityProviderConfig {
  id                    String                 @id @default(cuid())
  slug                  String                 @unique
  displayName           String
  type                  IdentityProviderType
  status                IdentityProviderStatus @default(staged)
  issuer                String?
  authorizationEndpoint String?
  tokenEndpoint         String?
  jwksUri               String?
  clientId              String?
  clientSecretRef       String?
  scopes                String[]
  samlSsoUrl            String?
  samlEntityId          String?
  samlCertificatePem    String?
  verifiedDomains       String[]
  groupClaim            String?
  emailClaim            String?
  subjectClaim          String?
  scimBearerTokenRef    String?
  userIdentities        UserIdentity[]
  userGroups            UserGroup[]
  sessions              Session[]
  provisioningCursors   ProvisioningCursor[]
  accessPolicyEvents    AccessPolicyEvent[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([status, type])
}

model UserIdentity {
  id                String               @id @default(cuid())
  userId            String
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId        String
  provider          IdentityProviderConfig @relation(fields: [providerId], references: [id], onDelete: Cascade)
  externalSubject   String
  email             String?
  displayName       String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  lastAuthenticatedAt DateTime?

  @@unique([providerId, externalSubject])
  @@index([userId])
}

model UserGroup {
  id           String               @id @default(cuid())
  providerId   String
  provider     IdentityProviderConfig @relation(fields: [providerId], references: [id], onDelete: Cascade)
  externalId   String
  name         String
  memberships  UserGroupMembership[]
  roleMapping  GroupRoleMapping?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([providerId, externalId])
  @@index([name])
}

model UserGroupMembership {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userGroupId String
  userGroup   UserGroup @relation(fields: [userGroupId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, userGroupId])
  @@index([userGroupId])
}

model GroupRoleMapping {
  id          String    @id @default(cuid())
  userGroupId String    @unique
  userGroup   UserGroup @relation(fields: [userGroupId], references: [id], onDelete: Cascade)
  role        Role
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ProvisioningCursor {
  id            String               @id @default(cuid())
  providerId    String
  provider      IdentityProviderConfig @relation(fields: [providerId], references: [id], onDelete: Cascade)
  cursorType    ProvisioningCursorType
  cursorValue   String?
  lastSyncedAt  DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([providerId, cursorType])
}

model AccessPolicyEvent {
  id           String                @id @default(cuid())
  providerId   String?
  provider     IdentityProviderConfig? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  actorId      String?
  actor        User?                 @relation("AccessPolicyActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetUserId String?
  targetUser   User?                 @relation("AccessPolicyTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  event        AccessPolicyEventType
  outcome      AccessPolicyOutcome
  reason       String?
  metadata     Json?
  createdAt    DateTime              @default(now())

  @@index([providerId, createdAt])
  @@index([targetUserId, createdAt])
}

enum Role {
  owner
  admin
  member
}

enum IdentityProviderType {
  oidc
  saml
}

enum IdentityProviderStatus {
  staged
  active
  disabled
}

enum SessionAuthMethod {
  local
  oidc
  saml
  break_glass
}

enum SessionAuthReason {
  local_login
  oidc_login
  saml_login
  password_reset
  break_glass
}

enum AuditEventCategory {
  application
  authentication
  provisioning
  authorization
  configuration
  export
  security
}

enum AuditOutcome {
  success
  denied
  failure
}

enum ProvisioningCursorType {
  scim_users
  scim_groups
}

enum AccessPolicyEventType {
  jit_provision
  scim_provision
  group_mapping_applied
  group_mapping_denied
  break_glass_login
  step_up_completed
  provider_configuration_changed
}

enum AccessPolicyOutcome {
  success
  denied
  failure
}

enum IdempotencyStatus {
  pending
  completed
}

enum OfferingType {
  product
  service
}

enum StartupStage {
  ideation
  validation
  prototype_mvp
  pre_launch
  launch
  product_market_fit
  growth_channel_fit
  revenue_validation
  operational_foundation
  early_scale
}

enum InnovationApproach {
  sustaining
  disruptive
}

enum EvaluationStatus {
  draft
  in_progress
  completed
  archived
}

enum EvaluationStep {
  start
  summary
  stage_1
  stage_2
  impact_summary
  sdg_alignment
  dashboard
  report
}

enum FinancialRoiLevel {
  not_evaluated
  below_industry_average
  average_or_no_benchmark
  above_industry_average
}

enum FinancialSensitivityLevel {
  not_evaluated
  high_volatility
  moderate_volatility
  low_volatility
}

enum FinancialUspLevel {
  not_evaluated
  no_usp
  weak_or_moderate_usp
  strong_or_unique_usp
}

enum FinancialMarketGrowthLevel {
  not_evaluated
  shrinking
  mature
  growing
}

enum TopicCode {
  E1
  E2
  E3
  E4
  E5
  S1
  S2
  S3
  S4
  G1
}

enum EvidenceBasis {
  measured
  estimated
  assumed
}

enum PriorityBand {
  not_applicable
  very_low
  low
  relevant
  high_priority
}

enum ImpactDimensionLevel {
  low
  moderate
  significant
  high
  na
}

enum ImpactLikelihoodLevel {
  very_unlikely
  unlikely
  likely
  very_likely
  na
}

enum RiskProbabilityLevel {
  rare
  could_occur
  likely
  very_likely
  na
}

enum RiskCode {
  climate_policy_risk
  water_scarcity_risk
  biodiversity_regulation_risk
  resource_scarcity_risk
  community_stability_risk
  consumer_governance_risk
}

enum OpportunityCode {
  climate_transition_opportunity
  water_reputation_opportunity
  biodiversity_reputation_opportunity
  circular_efficiency_opportunity
  community_reputation_opportunity
  governance_trust_opportunity
}

enum RiskRatingLabel {
  neutral
  sustainable
  moderate
  severe
  critical
}

enum OpportunityRatingLabel {
  neutral
  small
  reasonable
  sustainable
  great
}

enum ConfidenceBand {
  high
  moderate
  low
}

enum SdgSourceType {
  stage
  business
  both
}

enum RecommendationType {
  financial
  stage1
  risk
  opportunity
}

enum EvaluationArtifactKind {
  csv
  pdf
  ai_explanation
}

enum EvaluationArtifactStatus {
  pending
  processing
  ready
  failed
}

enum RecommendationActionStatus {
  not_started
  in_progress
  completed
  dismissed
}

enum EvaluationNarrativeKind {
  executive_summary
  material_topics
  risks_opportunities
  evidence_guidance
}

enum EvaluationNarrativeStatus {
  pending
  processing
  ready
  failed
}
